---
import '@fontsource-variable/outfit'
import '@fontsource/geist-mono'
import '@fontsource-variable/schibsted-grotesk'
import '@fontsource/bebas-neue/400.css'
import '../styles/global.css'
import schibstedGroteskUrl from '@fontsource-variable/schibsted-grotesk/files/schibsted-grotesk-latin-wght-normal.woff2?url'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={schibstedGroteskUrl} crossorigin />
    <title>RQ Systems</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="RQ Systems builds custom automation for businesses. We find what's still manual in your operation and build the software to replace it." />
    <link rel="canonical" href="https://rqsystems.pt" />

    <meta property="og:site_name" content="RQ Systems" />
    <meta property="og:title" content="RQ Systems — Your operations, automated." />
    <meta property="og:description" content="RQ Systems builds custom automation for businesses. We find what's still manual in your operation and build the software to replace it." />
    <meta property="og:url" content="https://rqsystems.pt" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en" />
    <meta property="og:image" content="https://rqsystems.pt/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="RQ Systems — Your operations, automated." />
    <meta name="twitter:description" content="RQ Systems builds custom automation for businesses." />
    <meta name="twitter:image" content="https://rqsystems.pt/og-image.png" />
  </head>
  <body class="bg-[#f5f5f5] text-[#0a0a0a] antialiased font-sans">
    <slot />
  </body>
</html>
