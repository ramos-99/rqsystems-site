---
import Layout from '../layouts/Layout.astro'
import DisplacementSphere from '../components/DisplacementSphere.tsx'
import HowWeWork from '../components/HowWeWork.tsx'
import CaseStudy from '../components/CaseStudy.tsx'
import Footer from '../components/Footer.tsx'
---

<Layout>
  <header class="fixed top-6 left-0 right-0 z-50 flex justify-center pointer-events-none">
    <nav class="pointer-events-auto w-[calc(100%-2rem)] md:w-auto md:min-w-[540px] flex items-center justify-between px-6 md:px-10 py-3 md:py-4 rounded-full mx-auto"
      style="
        background: rgba(7, 7, 7, 0.80);
        backdrop-filter: blur(24px) saturate(160%);
        -webkit-backdrop-filter: blur(24px) saturate(160%);
        border: 1px solid rgba(255,255,255,0.09);
        box-shadow: 0 0 0 1px rgba(0,0,0,0.5), 0 16px 48px rgba(0,0,0,0.65), inset 0 1px 0 rgba(255,255,255,0.07);
      ">
      <!-- Logo left -->
      <a href="#" class="flex items-center gap-2 no-underline">
        <span style="font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: white; letter-spacing: 0.06em; line-height: 1;">RQ</span>
        <span style="font-family: 'Gloock', serif; font-size: 1rem; color: #ccc; line-height: 1; letter-spacing: 0.01em;">Systems</span>
      </a>
      <!-- Center bar -->
      <span style="width:1px; height:18px; background: rgba(255,255,255,0.12); display:inline-block; flex-shrink:0;"></span>
      <!-- Contact right -->
      <a href="#contact"
        class="text-sm text-[#888] hover:text-white transition-colors duration-200 font-sans">
        Contact us
      </a>
    </nav>
  </header>

  <main>
    <section id="hero" class="relative min-h-screen flex items-center">

      <!-- Background, Resend-style: near-black base, soft ambient lift, blurred diagonal light beams -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <!-- Base + ambient: gentle lift behind the object and headline, fading to pure black at the bottom edge -->
        <div class="absolute inset-0" style="background:
          radial-gradient(80% 70% at 70% 42%, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 60%),
          radial-gradient(55% 50% at 22% 45%, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0) 60%),
          linear-gradient(to bottom, #0a0a0a 0%, #0a0a0a 72%, #000000 100%);"></div>
        <!-- Diagonal light beams sweeping across the lower half -->
        <div style="position: absolute; left: -15%; right: -15%; top: 60%; height: 160px; transform: rotate(-7deg); background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.06) 50%, rgba(255,255,255,0) 100%); filter: blur(32px);"></div>
        <div style="position: absolute; left: -15%; right: -15%; top: 76%; height: 100px; transform: rotate(-7deg); background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.04) 50%, rgba(255,255,255,0) 100%); filter: blur(24px);"></div>
        <!-- One brighter, tighter streak for definition -->
        <div style="position: absolute; left: -15%; right: -15%; top: 68%; height: 24px; transform: rotate(-7deg); background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.05) 35%, rgba(255,255,255,0.08) 55%, rgba(255,255,255,0) 100%); filter: blur(10px);"></div>
      </div>

      <!-- 3D canvas: absolute, right half, full section height — never clips -->
      <div class="absolute inset-y-0 right-0 hidden lg:block" style="width: 50%;">
        <DisplacementSphere client:visible />
      </div>

      <!-- Text: sits in left half, vertically centered, above the canvas -->
      <div class="relative w-full lg:w-1/2 px-6 md:px-16 pt-24 pb-12 md:pt-16 md:pb-16">
        <div class="max-w-lg">
          <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl xl:text-9xl text-white leading-none tracking-tight" style="font-family: 'Gloock', serif; font-weight: 400;">
            Your operations,<br />automated.
          </h1>
          <p class="text-sm text-[#888] mt-5 max-w-sm leading-relaxed">
            Built by <a href="#contact" class="text-white hover:text-emerald-400 transition-colors border-b border-white/20 hover:border-emerald-400/50">two Computer Science and Engineering students</a> from Técnico. We find what's still manual in your operations and build tailored software to replace it.
          </p>

          <div class="flex flex-wrap items-center gap-3 mt-8">
            <a href="#contact" class="px-5 py-2.5 bg-white text-black text-sm font-medium hover:bg-[#e5e5e5] transition-colors">
              Contact us
            </a>
            <a href="#what-we-do" class="px-5 py-2.5 border border-[#333] text-[#aaa] text-sm font-medium hover:text-white hover:border-white transition-colors">
              How we work
            </a>
            <a href="#case-study" class="px-5 py-2.5 border border-[#333] text-[#aaa] text-sm font-medium hover:text-white hover:border-white transition-colors">
              Featured work
            </a>
          </div>

          {/* Clean typographic stack logos */}
          <div class="mt-16 flex items-center gap-6 border-t border-[#222] pt-6 opacity-60 hover:opacity-100 transition-opacity duration-500">
            <span class="text-[10px] font-mono text-[#555] uppercase tracking-widest">Stack</span>
            <div class="flex items-center gap-5 text-[#888]">
              {/* Linux */}
              <span class="text-sm font-bold tracking-tight text-white/80">linux</span>
              <span class="w-1 h-1 rounded-full bg-[#333]"></span>
              {/* Claude */}
              <span class="text-sm" style="font-family: 'Gloock', serif; letter-spacing: 0.02em;">Claude</span>
              <span class="w-1 h-1 rounded-full bg-[#333]"></span>
              {/* Python */}
              <span class="text-sm font-semibold tracking-tighter" style="color: #6482A0;">python</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <HowWeWork client:only="react" />
    <CaseStudy client:only="react" />
    <Footer client:only="react" />
  </main>
</Layout>
