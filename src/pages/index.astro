---
import Layout from '../layouts/Layout.astro'
import DisplacementSphere from '../components/DisplacementSphere.tsx'
import WhatWeBuild from '../components/WhatWeBuild.tsx'
import CaseStudy from '../components/CaseStudy.tsx'
import Footer from '../components/Footer.tsx'
---

<Layout>
  <header class="fixed top-6 left-0 right-0 z-50 flex justify-center pointer-events-none">
    <nav class="pointer-events-auto w-[calc(100%-2rem)] md:w-auto md:min-w-[540px] flex items-center justify-between px-6 md:px-10 py-3 md:py-4 rounded-full mx-auto"
      style="
        background: rgba(255, 255, 255, 0.80);
        backdrop-filter: blur(24px) saturate(160%);
        -webkit-backdrop-filter: blur(24px) saturate(160%);
        border: 1px solid #d8d8d8;
        box-shadow: 0 0 0 1px rgba(0,0,0,0.04), 0 16px 48px rgba(0,0,0,0.12), inset 0 1px 0 rgba(255,255,255,0.6);
      ">
      <!-- Logo left -->
      <a href="#" class="flex items-center gap-2 no-underline">
        <span style="font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: #0a0a0a; letter-spacing: 0.06em; line-height: 1;">RQ</span>
        <span style="font-family: 'Schibsted Grotesk Variable', sans-serif; font-size: 1rem; color: #3f3f3f; line-height: 1; letter-spacing: 0.01em;">Systems</span>
      </a>
      <!-- Center bar -->
      <span style="width:1px; height:18px; background: rgba(10,10,10,0.14); display:inline-block; flex-shrink:0;"></span>
      <!-- Contact right -->
      <a href="#contact"
        class="text-sm text-[#3f3f3f] hover:text-[#0a0a0a] transition-colors duration-200 font-sans py-2 -my-2 px-2 -mx-2">
        Contact us
      </a>
    </nav>
  </header>

  <main>
    <section id="hero" class="relative min-h-svh flex items-center">

      <!-- Background: light gradient base, fine texture, dark corner rays, and passing black beams -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <!-- Gradient base (lightest section in the rhythm) -->
        <div class="absolute inset-0" style="background:
          radial-gradient(90% 80% at 72% 38%, #fcfcfc 0%, rgba(252,252,252,0) 55%),
          linear-gradient(180deg, #f7f7f7 0%, #efefef 100%);"></div>
        <!-- Soft dark illumination from the top-right corner -->
        <div class="absolute inset-0" style="background:
          radial-gradient(62% 62% at 100% 0%, rgba(10,10,10,0.07) 0%, transparent 70%);"></div>
        <!-- Visible soft diagonal light band sweeping the lower half -->
        <div style="position:absolute; left:-15%; right:-15%; top:60%; height:240px; transform:rotate(-7deg); filter:blur(56px); background:linear-gradient(to bottom, transparent 0%, rgba(10,10,10,0.08) 50%, transparent 100%);"></div>
        <!-- Brighter defined core line through the band -->
        <div style="position:absolute; left:-15%; right:-15%; top:71%; height:30px; transform:rotate(-7deg); filter:blur(13px); background:linear-gradient(to right, transparent 0%, rgba(10,10,10,0.08) 35%, rgba(10,10,10,0.15) 55%, transparent 95%);"></div>
      </div>

      <!-- 3D canvas: absolute, right half, full section height — never clips -->
      <div class="absolute inset-y-0 right-0 hidden lg:block" style="width: 50%;">
        <DisplacementSphere client:visible />
      </div>

      <!-- Text: sits in left half, vertically centered, above the canvas -->
      <div class="relative w-full lg:w-1/2 px-6 md:px-16 pt-24 pb-12 md:pt-16 md:pb-16">
        <div class="max-w-lg">
          <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl xl:text-9xl text-[#0a0a0a] leading-none tracking-tight" style="font-family: 'Schibsted Grotesk Variable', sans-serif; font-weight: 600;">
            Your operations,<br />automated.
          </h1>
          <p class="text-sm text-[#3f3f3f] mt-5 max-w-sm leading-relaxed">
            Built by <a href="#contact" class="text-[#0a0a0a] hover:text-emerald-700 transition-colors border-b border-[#0a0a0a]/30 hover:border-emerald-700/60">two engineers</a> from Técnico. We find what's still manual in your operations and build tailored software to automate it.
          </p>

          <div class="flex flex-wrap items-center gap-2.5 mt-8">
            <a href="#contact" class="px-5 py-2.5 bg-[#0a0a0a] text-[#f5f5f5] text-[13px] font-medium tracking-wide hover:bg-[#222] transition-colors duration-150">
              Contact us
            </a>
            <a href="#what-we-build" class="px-5 py-2.5 border border-[#0a0a0a]/30 text-[#3f3f3f] text-[13px] font-medium tracking-wide hover:text-[#0a0a0a] hover:border-[#0a0a0a]/60 transition-colors duration-150">
              What we build
            </a>
            <a href="#case-study" class="px-5 py-2.5 border border-[#0a0a0a]/30 text-[#3f3f3f] text-[13px] font-medium tracking-wide hover:text-[#0a0a0a] hover:border-[#0a0a0a]/60 transition-colors duration-150">
              Featured work
            </a>
          </div>

          <div class="mt-14 md:mt-20 border-t border-[#cfcfcf] pt-6">
            <p class="text-sm text-[#3f3f3f] font-sans italic">We work with whatever software you already use.</p>
          </div>
        </div>
      </div>
    </section>

    <WhatWeBuild client:only="react" />
    <CaseStudy client:only="react" />
    <Footer client:only="react" />
  </main>
</Layout>
